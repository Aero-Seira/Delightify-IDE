{
  "id": "forge_1.12",
  "name": "Forge 1.12.2 GameRegistry",
  "description": "Forge 1.12.2 using GameRegistry.register with direct registration",
  "appliesTo": {
    "loaders": ["forge"],
    "minecraftVersions": ["1.12", "1.11", "1.10", "1.9", "1.8", "1.7"]
  },
  "priority": 100,
  "enabled": true,
  "bytecodeSignatures": {
    "fieldTypes": [
      {
        "type": "Item",
        "modifiers": ["public", "static"],
        "registryType": "item",
        "score": 5
      },
      {
        "type": "Block",
        "modifiers": ["public", "static"],
        "registryType": "block",
        "score": 5
      }
    ],
    "methodCalls": [
      {
        "owner": "net/minecraftforge/fml/common/registry/GameRegistry",
        "name": "register",
        "score": 20
      },
      {
        "owner": "net/minecraftforge/fml/common/registry/ForgeRegistries",
        "name": "register",
        "score": 20
      },
      {
        "owner": "net/minecraftforge/registries/GameData",
        "name": "register_impl",
        "score": 15
      }
    ],
    "events": [
      {
        "class": "RegistryEvent$Register",
        "handlerAnnotation": "SubscribeEvent",
        "score": 25
      }
    ]
  },
  "extractionRules": {
    "eventRegistration": {
      "pattern": "EVENT_HANDLER",
      "eventClass": "RegistryEvent.Register",
      "methodName": "onRegisterItems",
      "extractFromEvent": {
        "registry": "event.getRegistry()",
        "entries": "registry.getEntries()"
      }
    },
    "staticRegistration": {
      "pattern": "STATIc_INIT",
      "inClinit": true,
      "methodCalls": [
        {
          "owner": "GameRegistry",
          "name": "register",
          "params": [
            {
              "index": 0,
              "type": "INSTANCE",
              "extractClass": true,
              "extractRegistryName": true
            }
          ]
        }
      ]
    },
    "setRegistryName": {
      "pattern": "CHAINED_CALL",
      "method": "setRegistryName",
      "params": [
        {
          "index": 0,
          "type": "STRING",
          "extractAs": "modId"
        },
        {
          "index": 1,
          "type": "STRING",
          "extractAs": "itemName"
        }
      ]
    }
  },
  "examples": [
    "public static final Item EXAMPLE = new Item().setRegistryName(\"modid\", \"example\").setUnlocalizedName(\"example\");",
    "GameRegistry.register(EXAMPLE);",
    "@SubscribeEvent public void onRegisterItems(RegistryEvent.Register<Item> event) { ... }"
  ]
}
