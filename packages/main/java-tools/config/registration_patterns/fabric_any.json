{
  "id": "fabric_any",
  "name": "Fabric Registry.register",
  "description": "Fabric loader using Registry.register static method",
  "appliesTo": {
    "loaders": ["fabric", "quilt"],
    "minecraftVersions": ["1.14", "1.15", "1.16", "1.17", "1.18", "1.19", "1.20", "1.21"]
  },
  "priority": 100,
  "enabled": true,
  "bytecodeSignatures": {
    "fieldTypes": [
      {
        "type": "Item",
        "modifiers": ["public", "static", "final"],
        "registryType": "item",
        "score": 5
      },
      {
        "type": "Block",
        "modifiers": ["public", "static", "final"],
        "registryType": "block",
        "score": 5
      }
    ],
    "methodCalls": [
      {
        "owner": "net/minecraft/core/Registry",
        "name": "register",
        "descriptor": "(Lnet/minecraft/core/Registry;Lnet/minecraft/resources/ResourceLocation;Ljava/lang/Object;)",
        "score": 20
      },
      {
        "owner": "net/minecraft/core/registry/Registries",
        "name": "register",
        "score": 20
      }
    ],
    "imports": [
      "net.fabricmc.fabric.api",
      "net.minecraft.core.Registry"
    ]
  },
  "extractionRules": {
    "registerCalls": {
      "pattern": "STATIC_REGISTER",
      "method": {
        "owner": "Registry",
        "name": "register",
        "params": [
          {
            "index": 0,
            "type": "REGISTRY_REFERENCE",
            "determineTypeFrom": "registryField"
          },
          {
            "index": 1,
            "type": "RESOURCE_LOCATION",
            "extractAs": "id"
          },
          {
            "index": 2,
            "type": "NEW_INSTANCE",
            "extractAs": "instance",
            "getClassFrom": "NEW"
          }
        ]
      }
    },
    "staticFields": {
      "pattern": "STATIC_FINAL_FIELD",
      "afterClinit": true,
      "fieldType": ["Item", "Block"],
      "extractIdFrom": "REGISTRY_NAME_METHOD"
    }
  },
  "examples": [
    "public static final Item EXAMPLE = Registry.register(Registry.ITEM, new Identifier(\"modid\", \"example\"), new Item(new Item.Settings()));"
  ]
}
